[32m+[m[32m// Dynamic supplier balance[m
[32m+[m[32mapp.get('/api/suppliers/:id/balance', (req, res) => {[m
[32m+[m[32m  try {[m
[32m+[m[32m    const supplierId = parseInt(req.params.id);[m
[32m+[m[32m    const supplier = db.prepare('SELECT * FROM suppliers WHERE id = ?').get(supplierId);[m
[32m+[m[32m    if (!supplier) return res.status(404).json({ error: 'Supplier not found' });[m
[32m+[m
[32m+[m[32m    const totalInvoiced = db.prepare(`SELECT COALESCE(SUM(total_amount), 0) as total FROM purchases WHERE supplier_id = ?`).get(supplierId).total;[m
[32m+[m[32m    const totalPaid = db.prepare(`[m
[32m+[m[32m      SELECT COALESCE(SUM(pp.amount), 0) as total[m
[32m+[m[32m      FROM purchases_payments pp[m
[32m+[m[32m      INNER JOIN purchases pur ON pp.purchase_id = pur.id[m
[32m+[m[32m      WHERE pur.supplier_id = ?[m
[32m+[m[32m    `).get(supplierId).total;[m
[32m+[m
[32m+[m[32m    const balance = totalInvoiced - totalPaid;  // positive = we owe, negative = supplier credit[m
[32m+[m[32m    const supplier_credit = balance < 0 ? Math.abs(balance) : 0;[m
[32m+[m
[32m+[m[32m    res.json({[m
[32m+[m[32m      supplier_id: supplierId,[m
[32m+[m[32m      supplier_name: supplier.name,[m
[32m+[m[32m      total_invoiced: totalInvoiced,[m
[32m+[m[32m      total_paid: totalPaid,[m
[32m+[m[32m      balance,          // positive = we owe supplier, negative = supplier owes us[m
[32m+[m[32m      supplier_credit   // amount supplier owes us (available to apply to next invoice)[m
[32m+[m[32m    });[m
[32m+[m[32m  } catch (err) { res.status(500).json({ error: err.message }); }[m
[32m+[m[32m});[m
[32m+[m
 // ============================================[m
 // API ENDPOINTS - CHECKS[m
